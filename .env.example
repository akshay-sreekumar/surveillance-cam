# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Camera settings (can be an integer like 0 for local webcam, or a string URL like 'http://192.168.1.100:4747/video' for phone via DroidCam/IP Webcam)
CAMERA_INDEX=0

# Detection thresholds
CROWD_DENSITY_THRESHOLD=50
VIOLENCE_MOTION_THRESHOLD=15.0 # Threshold for optical flow indicating erratic motion
FALL_DETECTION_ASPECT_RATIO=1.2 # If a bounding box width/height > this, flag as fallen/slumped
DECISION_CONFIDENCE_THRESHOLD=0.85
COOLDOWN_SECONDS=30
